APP_NAME=SimdiGetir
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul
APP_URL=http://localhost
APP_VERSION=1.0.18
SANCTUM_TOKEN_EXPIRATION=1440
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1,http://127.0.0.1:8000

