APP_NAME=SimdiGetir
APP_VERSION=1.3.0
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://simdigetir.com
GOOGLE_TAG_ID=G-XYCY1D28EF
GOOGLE_ADS_ID=AW-17989545006
APP_TIMEZONE=Europe/Istanbul
SANCTUM_TOKEN_EXPIRATION=1440
CORS_ALLOWED_ORIGINS=https://simdigetir.com

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpanel_db_name
DB_USERNAME=cpanel_db_user
DB_PASSWORD=replace_with_secure_db_password

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=mail.simdigetir.com
MAIL_PORT=587
MAIL_USERNAME=info@simdigetir.com
MAIL_PASSWORD=replace_with_real_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@simdigetir.com
MAIL_FROM_NAME="${APP_NAME}"

PAYMENT_REQUIRED=false
PAYMENT_DEFAULT_PROVIDER=mockpay
PAYTR_MERCHANT_ID=replace_with_paytr_merchant_id
PAYTR_MERCHANT_KEY=replace_with_paytr_merchant_key
PAYTR_MERCHANT_SALT=replace_with_paytr_merchant_salt
PAYTR_BASE_URL=https://www.paytr.com
PAYTR_SANDBOX=false
PAYTR_CALLBACK_SECRET=replace_with_paytr_callback_secret
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_SANDBOX=false
IYZICO_CALLBACK_SECRET=

SMS_DEFAULT_PROVIDER=netgsm
NETGSM_USERNAME=replace_with_netgsm_username
NETGSM_PASSWORD=replace_with_netgsm_password
NETGSM_HEADER=replace_with_netgsm_header
NETGSM_BASE_URL=https://api.netgsm.com.tr
NETGSM_SANDBOX=false

GOOGLE_MAPS_API_KEY=replace_with_maps_api_key
META_PIXEL_ID=1657531168735846
META_CAPI_ENABLED=true
META_CAPI_ACCESS_TOKEN=replace_with_meta_capi_access_token
META_CAPI_TEST_EVENT_CODE=
META_GRAPH_VERSION=v22.0
META_CAPI_TIMEOUT_SECONDS=10

ADS_CONVERSION_ENABLED=true
ADS_CONVERSION_AUTO_PUSH=true
ADS_CONVERSION_AUTO_PUSH_MODE=sync
ADS_CONVERSION_AUTO_PUSH_PLATFORMS=meta

LIVE_SMOKE_BASE_URL=https://simdigetir.com
LIVE_SMOKE_ADMIN_EMAIL=admin@simdigetir.com
LIVE_SMOKE_ADMIN_PASSWORD=replace_with_admin_password
LIVE_SMOKE_SMS_TARGET=905xxxxxxxxx
LIVE_SMOKE_EMAIL_TARGET=ops@simdigetir.com
