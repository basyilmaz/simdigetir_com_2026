APP_NAME=SimdiGetir
APP_VERSION=1.0.3
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://simdigetir.com
APP_TIMEZONE=Europe/Istanbul

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpanel_db_name
DB_USERNAME=cpanel_db_user
DB_PASSWORD=replace_with_secure_db_password

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=mail.simdigetir.com
MAIL_PORT=587
MAIL_USERNAME=info@simdigetir.com
MAIL_PASSWORD=replace_with_real_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@simdigetir.com
MAIL_FROM_NAME="${APP_NAME}"

PAYMENT_REQUIRED=false
PAYMENT_DEFAULT_PROVIDER=mockpay
IYZICO_API_KEY=replace_with_iyzico_api_key
IYZICO_SECRET_KEY=replace_with_iyzico_secret_key
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_SANDBOX=false
IYZICO_CALLBACK_SECRET=replace_with_iyzico_callback_secret

SMS_DEFAULT_PROVIDER=netgsm
NETGSM_USERNAME=replace_with_netgsm_username
NETGSM_PASSWORD=replace_with_netgsm_password
NETGSM_HEADER=replace_with_netgsm_header
NETGSM_BASE_URL=https://api.netgsm.com.tr
NETGSM_SANDBOX=false

GOOGLE_MAPS_API_KEY=replace_with_maps_api_key

LIVE_SMOKE_BASE_URL=https://simdigetir.com
LIVE_SMOKE_ADMIN_EMAIL=admin@simdigetir.com
LIVE_SMOKE_ADMIN_PASSWORD=replace_with_admin_password
LIVE_SMOKE_SMS_TARGET=905xxxxxxxxx
LIVE_SMOKE_EMAIL_TARGET=ops@simdigetir.com
